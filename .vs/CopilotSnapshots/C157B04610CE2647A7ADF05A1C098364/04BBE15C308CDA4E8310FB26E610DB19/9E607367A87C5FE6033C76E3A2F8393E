            DrawRectangle(_spriteBatch, new Rectangle(10, bottomY, 500, 110), Color.Black * 0.7f);
            
            // We'd normally draw text here, but without a font we'll just show a control panel box
            // If you add a SpriteFont, you can uncomment and use this:
